{
  "ConnectionStrings": {
    "RfidDatabase": "Host=localhost;Port=5432;Database=RfidPrintDB;Username=postgres;Password=admin"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/rfidprint-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}